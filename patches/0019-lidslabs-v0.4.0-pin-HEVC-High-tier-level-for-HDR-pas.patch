From bd61698c2ee1d4b3a1c3392412b775f3e44951b0 Mon Sep 17 00:00:00 2001
From: Lids Labs <55252374+lidslabs@users.noreply.github.com>
Date: Thu, 23 Jul 2026 09:43:55 -0400
Subject: [PATCH 19/19] lidslabs v0.4.0: pin HEVC High tier + level for HDR
 passthrough, advertise matching CODECS

NVENC picks general_tier_flag AND general_level_idc adaptively by bitrate, but
the HLS CODECS string is static. Two independent drifts made the manifest lie:
  - tier: GetH265String hardcoded Main ('L'); NVENC emits High above ~16 Mbps.
  - level: DynamicHlsHelper advertises L5.1 (153) for all 2160p (patch 0010), but
    NVENC emitted L5.0 (150) for a 2160p 16 Mbps HDR encode -- the patch-0010
    assumption 'NVENC emits L5.1 for 4k' is false at this bitrate.
Verified on dev: bitstream hvcC = hvc1.2.4.H150.B0 vs manifest hvc1.2.4.H153.B0.
Apple AVPlayer (Swiftfin, Neptune AV) validates the advertised string against the
init segment's hvcC: on a tier OR level mismatch it fetches the media playlist and
then silently refuses (never requests the init segment) -> playback fails even
though the same file direct-plays (its own hvcC carries the real values). Copy
path works because it advertises the source's real string.

Fix, scoped to HDR passthrough HEVC transcodes:
- EncodingHelper.GetVideoQualityParam: force -tier:v high -level:v <5.1 for 2160p,
  else 5.0> on hevc_nvenc. Forcing a level at/above NVENC's own pick is safe (the
  '-level can fail NVENC' caveat is about levels too LOW). Confirmed on dev the
  encode then emits exactly hvc1.2.4.H153.B0.
- HlsCodecStringHelpers.GetH265String: new highTier param -> 'H' vs 'L' (defaults
  to 'L'; all other callers/paths unchanged).
- DynamicHlsHelper.GetPlaylistVideoCodecs: advertise High tier when
  IsHdrPassthroughMode && !copy.

Client-agnostic manifest-correctness fix (extends patch 0010), not a per-client
workaround; also expected to restore HDR transcode for Neptune AV.
---
 Jellyfin.Api/Helpers/DynamicHlsHelper.cs      | 13 ++++++++++-
 Jellyfin.Api/Helpers/HlsCodecStringHelpers.cs | 13 ++++++++---
 .../MediaEncoding/EncodingHelper.cs           | 22 +++++++++++++++++++
 3 files changed, 44 insertions(+), 4 deletions(-)

diff --git a/Jellyfin.Api/Helpers/DynamicHlsHelper.cs b/Jellyfin.Api/Helpers/DynamicHlsHelper.cs
index 295176c3c0..abd527a112 100644
--- a/Jellyfin.Api/Helpers/DynamicHlsHelper.cs
+++ b/Jellyfin.Api/Helpers/DynamicHlsHelper.cs
@@ -841,7 +841,18 @@ public class DynamicHlsHelper
             || string.Equals(codec, "hevc", StringComparison.OrdinalIgnoreCase))
         {
             string profile = GetOutputVideoCodecProfile(state, "hevc");
-            return HlsCodecStringHelpers.GetH265String(profile, level);
+
+            // HDR passthrough transcodes are pinned to High tier in the NVENC encoder
+            // args (EncodingHelper.GetVideoQualityParam adds -tier:v high) so the tier
+            // is deterministic across the bitrate range. NVENC otherwise picks the tier
+            // adaptively (Main below ~16 Mbps, High above), which left the advertised
+            // 'L' string mismatched against a High-tier bitstream -- Apple AVPlayer
+            // (Swiftfin / Neptune AV) rejects that mismatch and refuses the HDR
+            // transcode. Advertise 'H' to match. Copy and SDR paths keep Main-tier
+            // signalling untouched.
+            bool highTier = EncodingHelper.IsHdrPassthroughMode(state)
+                && !EncodingHelper.IsCopyCodec(state.OutputVideoCodec);
+            return HlsCodecStringHelpers.GetH265String(profile, level, highTier);
         }
 
         if (string.Equals(codec, "av1", StringComparison.OrdinalIgnoreCase))
diff --git a/Jellyfin.Api/Helpers/HlsCodecStringHelpers.cs b/Jellyfin.Api/Helpers/HlsCodecStringHelpers.cs
index 0efb7f45de..86f79f3dd0 100644
--- a/Jellyfin.Api/Helpers/HlsCodecStringHelpers.cs
+++ b/Jellyfin.Api/Helpers/HlsCodecStringHelpers.cs
@@ -156,12 +156,19 @@ public static class HlsCodecStringHelpers
     /// </summary>
     /// <param name="profile">H.265 profile.</param>
     /// <param name="level">H.265 level.</param>
+    /// <param name="highTier">Whether the bitstream is High tier (general_tier_flag=1) rather than Main tier.</param>
     /// <returns>H.265 string.</returns>
-    public static string GetH265String(string? profile, int level)
+    public static string GetH265String(string? profile, int level, bool highTier = false)
     {
         // The h265 syntax is a bit of a mystery at the time this comment was written.
         // This is what I've found through various sources:
-        // FORMAT: [codecTag].[profile].[constraint?].L[level * 30].[UNKNOWN]
+        // FORMAT: [codecTag].[profile].[constraint?].[tier][level * 30].[UNKNOWN]
+        // The tier char is 'L' for Main tier (general_tier_flag=0) and 'H' for High
+        // tier (general_tier_flag=1). Strict HLS players (Apple AVPlayer) reject the
+        // stream if the advertised tier does not match the bitstream, so callers that
+        // pin the encoder to High tier must advertise 'H' here. See
+        // DynamicHlsHelper.GetPlaylistVideoCodecs and the NVENC -tier:v high in
+        // EncodingHelper.GetVideoQualityParam.
         StringBuilder result = new StringBuilder("hvc1", 16);
 
         if (string.Equals(profile, "main10", StringComparison.OrdinalIgnoreCase)
@@ -175,7 +182,7 @@ public static class HlsCodecStringHelpers
             result.Append(".1.4");
         }
 
-        result.Append(".L")
+        result.Append(highTier ? ".H" : ".L")
             .Append(level)
             .Append(".B0");
 
diff --git a/MediaBrowser.Controller/MediaEncoding/EncodingHelper.cs b/MediaBrowser.Controller/MediaEncoding/EncodingHelper.cs
index 516da8fa5c..ca362f5736 100644
--- a/MediaBrowser.Controller/MediaEncoding/EncodingHelper.cs
+++ b/MediaBrowser.Controller/MediaEncoding/EncodingHelper.cs
@@ -2282,6 +2282,28 @@ namespace MediaBrowser.Controller.MediaEncoding
                 }
             }
 
+            // HDR passthrough: pin hevc_nvenc to a deterministic tier AND level so the
+            // bitstream matches the static HLS CODECS string. NVENC otherwise picks both
+            // adaptively -- observed a 2160p 16 Mbps HDR encode emit High tier but
+            // general_level_idc=150 (L5.0) while DynamicHlsHelper advertised L5.1 (153).
+            // Apple AVPlayer (Swiftfin / Neptune AV) validates the advertised codec
+            // string against the init segment's hvcC: on a tier OR level mismatch it
+            // fetches the media playlist, then silently refuses (never requests the init
+            // segment) -- playback fails even though the client can direct-play the same
+            // file (whose own hvcC carries the real values, no manifest to contradict).
+            // Force High tier + the same resolution-based level the manifest advertises
+            // (2160p -> L5.1, else L5.0). Forcing a level at/above what NVENC would pick
+            // is safe -- the "-level can fail NVENC" caveat is about levels too LOW for
+            // the content; High-tier L5.1 covers our full bitrate range so it never
+            // constrains quality. Matches HlsCodecStringHelpers.GetH265String ('H') and
+            // NormalizeTranscodingLevel's cap.
+            if (IsHdrPassthroughMode(state)
+                && string.Equals(videoEncoder, "hevc_nvenc", StringComparison.OrdinalIgnoreCase))
+            {
+                var hdrLevelToken = (state.OutputHeight >= 2160 || state.OutputWidth >= 3840) ? "5.1" : "5";
+                param += " -tier:v high -level:v " + hdrLevelToken;
+            }
+
             var level = NormalizeTranscodingLevel(state, state.GetRequestedLevel(targetVideoCodec));
 
             if (!string.IsNullOrEmpty(level))
